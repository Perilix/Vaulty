# Copier en .env pour le dev local (docker-compose fournit déjà ces valeurs au conteneur)
PORT=3000

# Base de données — soit DATABASE_URL, soit les PG* ci-dessous
# DATABASE_URL=postgresql://vaulty:vaulty@localhost:5432/vaulty
PGHOST=localhost
PGPORT=5432
PGUSER=vaulty
PGPASSWORD=vaulty
PGDATABASE=vaulty

# Authentification
APP_PASSWORD=vaulty
JWT_SECRET=change-moi-en-prod

# Lancer la migration au démarrage (true par défaut)
AUTO_MIGRATE=true
